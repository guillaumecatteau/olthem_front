{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Watch SCSS",
      "type": "shell",
      "command": "npm.cmd run scss:watch",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Build SCSS",
      "type": "shell",
      "command": "npm.cmd run scss:build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
